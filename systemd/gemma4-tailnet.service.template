[Unit]
Description=Gemma 4 OpenAI-compatible API on Tailscale
After=network-online.target tailscaled.service docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=__WORKING_DIR__
ExecStart=/usr/bin/docker compose --env-file __WORKING_DIR__/.env -f __WORKING_DIR__/compose.yaml up -d
ExecStop=/usr/bin/docker compose --env-file __WORKING_DIR__/.env -f __WORKING_DIR__/compose.yaml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
